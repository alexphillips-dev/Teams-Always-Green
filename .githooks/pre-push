#!/bin/sh

if command -v pwsh >/dev/null 2>&1; then
  PS_BIN="pwsh"
elif command -v powershell >/dev/null 2>&1; then
  PS_BIN="powershell"
else
  echo "pre-push: PowerShell is required to run privacy checks."
  exit 1
fi

ZERO40="0000000000000000000000000000000000000000"
scan_count=0

while read local_ref local_sha remote_ref remote_sha
do
  if [ -z "$local_sha" ]; then
    continue
  fi
  if [ "$local_sha" = "$ZERO40" ]; then
    continue
  fi

  if [ "$remote_sha" = "$ZERO40" ] || [ -z "$remote_sha" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  "$PS_BIN" -NoLogo -NoProfile -ExecutionPolicy Bypass -File "Tools/Find-PrivacyLeaks.ps1" -MetadataOnly -CommitRange "$range"
  status=$?
  if [ $status -ne 0 ]; then
    echo "pre-push: blocked by metadata privacy/security scan for range $range."
    exit $status
  fi
  scan_count=$((scan_count + 1))
done

if [ $scan_count -eq 0 ]; then
  "$PS_BIN" -NoLogo -NoProfile -ExecutionPolicy Bypass -File "Tools/Find-PrivacyLeaks.ps1" -MetadataOnly
  status=$?
  if [ $status -ne 0 ]; then
    echo "pre-push: blocked by metadata privacy/security scan."
    exit $status
  fi
fi

exit 0
